# NYRA — top-level editorconfig.
# Phase 12-C: end the tabs-vs-spaces drift across .cpp / .h files.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{cpp,h,hpp,inl}]
indent_style = space
indent_size = 4

[*.py]
indent_style = space
indent_size = 4
max_line_length = 100

[*.{cs}]
indent_style = space
indent_size = 4

[*.{md,markdown}]
trim_trailing_whitespace = false
indent_size = 2

[*.{json,yml,yaml,toml}]
indent_size = 2

[Makefile]
indent_style = tab
