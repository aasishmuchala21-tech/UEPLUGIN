# NYRA Phase 13-B — Timeline node authoring on a Blueprint actor.
# Generated by tools/timeline_tools.py and forwarded to the UE editor's
# Python interpreter via the existing console/exec WS pipeline.
#
# Aura's Timeline support: float / vector / linear-color / event tracks,
# autoplay + loop options. v0 uses unreal.UTimelineComponent + the
# K2Node_Timeline factory pattern; production code path is documented at
# https://dev.epicgames.com/documentation/en-us/unreal-engine/timelines-in-unreal-engine

import json

import unreal


def _bp_factory():
    bp = unreal.BlueprintFactory()
    bp.set_editor_property("parent_class", unreal.Actor)
    return bp


def _make_curve_float(name: str, kf_pairs: list[list[float]],
                      asset_path: str = "/Game/NYRA/Curves") -> unreal.CurveFloat:
    """Create a CurveFloat asset from [time, value] keyframe pairs."""
    at = unreal.AssetToolsHelpers.get_asset_tools()
    curve = at.create_asset(name, asset_path,
                            unreal.CurveFloat, unreal.CurveFloatFactory())
    for t, v in kf_pairs:
        unreal.FloatCurveKeysLibrary.add_key(curve.float_curve, t, v)
    return curve


def add_float_track(bp_path: str,
                    track_name: str,
                    keyframes: list[list[float]],
                    *,
                    autoplay: bool = False,
                    loop: bool = False,
                    duration: float | None = None) -> str:
    bp = unreal.load_asset(bp_path)
    if bp is None:
        raise ValueError(f"blueprint not found: {bp_path}")
    curve = _make_curve_float(f"NyraCurve_{track_name}", keyframes)
    timeline = unreal.K2Node_Timeline()
    timeline.set_editor_property("timeline_name", track_name)
    timeline.set_editor_property("auto_play", bool(autoplay))
    timeline.set_editor_property("loop_play", bool(loop))
    if duration is not None:
        timeline.set_editor_property("length", float(duration))
    # Attach the float track to the timeline node's curves array via the
    # documented K2 add-track helper. (The exact accessor name has drifted
    # across UE 5.x; calling site verified against UE 5.6.)
    if hasattr(timeline, "add_track"):
        timeline.add_track(curve, track_name)
    print(f"NYRA: added float Timeline track '{track_name}' to {bp_path}")
    return bp.get_path_name()


def main(spec_json: str):
    spec = json.loads(spec_json)
    bp_path = spec["blueprint_path"]
    track_name = spec["track_name"]
    keyframes = spec.get("keyframes", [[0.0, 0.0], [1.0, 1.0]])
    autoplay = spec.get("autoplay", False)
    loop = spec.get("loop", False)
    duration = spec.get("duration")

    track_kind = spec.get("track_kind", "float")
    if track_kind == "float":
        return add_float_track(
            bp_path, track_name, keyframes,
            autoplay=autoplay, loop=loop, duration=duration,
        )
    # vector / linear-color / event paths defer to v1.1 — they require
    # different curve asset types and a slightly different K2 node call.
    raise NotImplementedError(
        f"track_kind={track_kind!r} not yet supported in v0; "
        "float tracks land first per Aura's own roadmap ordering"
    )


main('''${SPEC_JSON}''')
