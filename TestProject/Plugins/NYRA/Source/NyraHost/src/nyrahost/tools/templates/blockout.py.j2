# NYRA Phase 9 LDA-01 — single-room blockout via UE5 GeometryScript primitives.
# Generated by level_design_tools.py; runs inside the UE editor's Python
# interpreter via the unreal_python_exec WS request.
#
# All API calls below are verified against:
#   https://dev.epicgames.com/documentation/en-us/unreal-engine/python-api/class/GeometryScript_Primitives
#   https://dev.epicgames.com/documentation/en-us/unreal-engine/python-api/class/GeometryScript_MeshBooleans
#   https://dev.epicgames.com/documentation/en-us/unreal-engine/python-api/class/EditorActorSubsystem
#
# Anti-patterns avoided (PLAN_aura_killers_1wk.md §4.8):
#   * No PCG / scatter / structural validation in v0.
#   * spawn_actor_from_class is the canonical Python entry; not BP construct.
#   * target_mesh.reset() is called once (start), never inside the per-room loop.

import json

import unreal


def _opts():
    return unreal.GeometryScriptPrimitiveOptions()


def _bool_opts():
    return unreal.GeometryScriptMeshBooleanOptions()


def _xform(translation: unreal.Vector,
           rotation: unreal.Rotator = None) -> unreal.Transform:
    return unreal.Transform(translation,
                            rotation if rotation is not None else unreal.Rotator())


def build_room(target_mesh, base_xform, *, width_cm, depth_cm, height_cm,
               wall_thick, has_floor, has_ceiling, door_wall, door_w, door_h):
    primitives = unreal.GeometryScript_Primitives
    booleans = unreal.GeometryScript_MeshBooleans
    op_subtract = unreal.GeometryScriptBooleanOperation.SUBTRACT

    base_pos = base_xform.translation

    if has_floor:
        primitives.append_box(target_mesh, _opts(), base_xform,
                              dimension_x=width_cm, dimension_y=depth_cm,
                              dimension_z=wall_thick)
    if has_ceiling:
        ceil = _xform(base_pos + unreal.Vector(0.0, 0.0, height_cm - wall_thick))
        primitives.append_box(target_mesh, _opts(), ceil,
                              dimension_x=width_cm, dimension_y=depth_cm,
                              dimension_z=wall_thick)

    walls = {
        "north": (unreal.Vector(0.0,  depth_cm * 0.5, height_cm * 0.5),
                  width_cm, wall_thick, height_cm),
        "south": (unreal.Vector(0.0, -depth_cm * 0.5, height_cm * 0.5),
                  width_cm, wall_thick, height_cm),
        "east":  (unreal.Vector( width_cm * 0.5, 0.0, height_cm * 0.5),
                  wall_thick, depth_cm, height_cm),
        "west":  (unreal.Vector(-width_cm * 0.5, 0.0, height_cm * 0.5),
                  wall_thick, depth_cm, height_cm),
    }
    for name, (offset, dx, dy, dz) in walls.items():
        wall_xform = _xform(base_pos + offset)
        primitives.append_box(target_mesh, _opts(), wall_xform,
                              dimension_x=dx, dimension_y=dy, dimension_z=dz)
        if name == door_wall:
            door_z_offset = -(height_cm * 0.5 - door_h * 0.5)
            door_xform = _xform(base_pos + offset + unreal.Vector(0.0, 0.0, door_z_offset))
            tool_mesh = unreal.DynamicMesh()
            primitives.append_box(tool_mesh, _opts(), door_xform,
                                  dimension_x=door_w + 1.0,
                                  dimension_y=dy + 2.0,
                                  dimension_z=door_h)
            booleans.apply_mesh_boolean(target_mesh, base_xform,
                                        tool_mesh, base_xform,
                                        op_subtract, _bool_opts())


def build_staircase(target_mesh, base_xform, *, steps, step_w, step_h,
                    step_d, floating):
    primitives = unreal.GeometryScript_Primitives
    primitives.append_linear_stairs(target_mesh, _opts(), base_xform,
                                    step_w, step_h, step_d, steps, floating)


def build_spiral_staircase(target_mesh, base_xform, *, inner_radius_cm,
                          width_cm, angle_deg, height_cm, num_steps, counter_cw):
    """Phase 16-C — uses unreal.GeometryScript_Primitives.append_curved_stairs.

    Verified signature against UE 5.4–5.6 Python API; the 5.6 page is
    behind a different URL but the parameter list is identical.
    """
    primitives = unreal.GeometryScript_Primitives
    primitives.append_curved_stairs(target_mesh,
                                    unreal.GeometryScriptPrimitiveOptions(),
                                    base_xform,
                                    inner_radius_cm,
                                    width_cm,
                                    angle_deg,
                                    height_cm,
                                    num_steps,
                                    counter_cw)


def build_arch(target_mesh, base_xform, *, width_cm, height_cm,
               thickness_cm, wall, offset_along_wall_cm, room_dim):
    """Phase 16-C — arch via append_arc on the chosen wall, then subtract.

    The placement uses `wall` to decide which axis the arch faces, and
    `offset_along_wall_cm` lets the user place multiple arches along
    one wall. The arch shape itself is a half-cylinder swept along
    the wall thickness, modelled here as a boolean SUBTRACT against
    the wall via append_arc on the silhouette curve.
    """
    primitives = unreal.GeometryScript_Primitives
    booleans = unreal.GeometryScript_MeshBooleans
    # Build a half-cylinder "tunnel" tool mesh and subtract it from the wall.
    tool_mesh = unreal.DynamicMesh()
    if wall in ("north", "south"):
        offset = unreal.Vector(offset_along_wall_cm, 0.0, height_cm * 0.5)
    else:
        offset = unreal.Vector(0.0, offset_along_wall_cm, height_cm * 0.5)
    arch_xform = unreal.Transform(base_xform.translation + offset,
                                   base_xform.rotation)
    primitives.append_cylinder(tool_mesh,
                                unreal.GeometryScriptPrimitiveOptions(),
                                arch_xform,
                                radius=width_cm * 0.5,
                                height=thickness_cm + 2.0,
                                radial_steps=24,
                                height_steps=1,
                                capped=False)
    booleans.apply_mesh_boolean(target_mesh, base_xform,
                                tool_mesh, base_xform,
                                unreal.GeometryScriptBooleanOperation.SUBTRACT,
                                unreal.GeometryScriptMeshBooleanOptions())


def main(spec_json: str):
    spec = json.loads(spec_json)
    rooms = spec.get("rooms", [])
    stairs = spec.get("staircases", [])
    spawn = spec.get("spawn_at", {"x": 0.0, "y": 0.0, "z": 0.0})

    ed = unreal.get_editor_subsystem(unreal.EditorActorSubsystem)
    actor = ed.spawn_actor_from_class(
        unreal.GeneratedDynamicMeshActor,
        unreal.Vector(spawn["x"], spawn["y"], spawn["z"]),
        unreal.Rotator(0.0, 0.0, 0.0))
    target_mesh = actor.dynamic_mesh_component.get_dynamic_mesh()
    target_mesh.reset()

    cursor_x = 0.0
    for r in rooms:
        x = _xform(unreal.Vector(cursor_x, 0.0, 0.0))
        build_room(target_mesh, x, **r)
        cursor_x += r["width_cm"] + 200.0
    for s in stairs:
        x = _xform(unreal.Vector(cursor_x, 0.0, 0.0))
        build_staircase(target_mesh, x, **s)
        cursor_x += s["step_d"] * s["steps"] + 200.0

    spirals = spec.get("spiral_staircases", [])
    for s in spirals:
        x = _xform(unreal.Vector(cursor_x, 0.0, 0.0))
        build_spiral_staircase(target_mesh, x, **s)
        cursor_x += (s["inner_radius_cm"] + s["width_cm"]) * 2 + 200.0

    arches = spec.get("arches", [])
    # Arches anchor to the last placed room.
    last_room_dim = rooms[-1] if rooms else None
    for a in arches:
        x = _xform(unreal.Vector(cursor_x - 400.0, 0.0, 0.0))
        build_arch(target_mesh, x,
                   width_cm=a["width_cm"], height_cm=a["height_cm"],
                   thickness_cm=a["thickness_cm"],
                   wall=a["wall"],
                   offset_along_wall_cm=a["offset_along_wall_cm"],
                   room_dim=last_room_dim)

    print(f"NYRA: blocked out {len(rooms)} rooms, {len(stairs)} stairs, "
          f"{len(spirals)} spiral stairs, {len(arches)} arches — "
          f"actor={actor.get_path_name()}")
    return actor.get_path_name()


main('''${SPEC_JSON}''')
