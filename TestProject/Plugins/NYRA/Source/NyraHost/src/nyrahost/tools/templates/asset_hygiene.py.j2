# NYRA Phase 13-C — Asset Hygiene Agent.
# Generated by tools/asset_hygiene.py and forwarded to the UE editor's
# Python interpreter. Whole-project agent that:
#   1. Walks /Game/ via the AssetRegistry
#   2. Detects unused assets (no inbound references)
#   3. Detects naming-convention violations vs project rules
#   4. Detects orphan asset references in actor properties
#
# Aura ships per-domain agents (BP, Niagara, AnimBP, ...). NYRA's whole-
# project Hygiene agent is a Tier 2 moat — Aura's pricing model would
# bankrupt them at the per-asset cost a 50K-asset project incurs.

import json

import unreal


def _registry():
    return unreal.AssetRegistryHelpers.get_asset_registry()


def find_unused_assets(under: str = "/Game") -> list[dict]:
    """Return every asset under `under` with no inbound hard refs."""
    reg = _registry()
    assets = reg.get_assets_by_path(under, recursive=True)
    out = []
    for a in assets:
        path = a.get_full_name()
        # AssetRegistry has find_referencers for every asset.
        refs = reg.get_referencers(a.package_name)
        if not refs:
            out.append({
                "path": str(a.package_name),
                "class": str(a.asset_class),
                "name": str(a.asset_name),
            })
    return out


def find_naming_violations(rules: dict, under: str = "/Game") -> list[dict]:
    """Return assets whose names violate the per-class prefix/suffix rules.

    rules: { "<class_name>": "<prefix_or_suffix_rule>" }
      e.g. {"Blueprint": "BP_*", "Texture2D": "T_*", "Material": "M_*"}
    """
    reg = _registry()
    out = []
    for a in reg.get_assets_by_path(under, recursive=True):
        rule = rules.get(str(a.asset_class))
        if rule is None:
            continue
        name = str(a.asset_name)
        if rule.endswith("*"):
            prefix = rule[:-1]
            if not name.startswith(prefix):
                out.append({
                    "path": str(a.package_name),
                    "class": str(a.asset_class),
                    "expected": rule,
                    "actual": name,
                })
        elif rule.startswith("*"):
            suffix = rule[1:]
            if not name.endswith(suffix):
                out.append({
                    "path": str(a.package_name),
                    "class": str(a.asset_class),
                    "expected": rule,
                    "actual": name,
                })
    return out


def main(spec_json: str):
    spec = json.loads(spec_json)
    under = spec.get("under", "/Game")
    rules = spec.get("naming_rules", {})

    report = {
        "under": under,
        "unused": find_unused_assets(under) if spec.get("find_unused", True) else [],
        "naming_violations": (
            find_naming_violations(rules, under)
            if spec.get("find_naming_violations", True) and rules else []
        ),
    }
    print(f"NYRA HYGIENE: {len(report['unused'])} unused, "
          f"{len(report['naming_violations'])} naming violations")
    return json.dumps(report)


main('''${SPEC_JSON}''')
