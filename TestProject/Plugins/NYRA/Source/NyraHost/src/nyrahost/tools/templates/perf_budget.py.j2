# NYRA Phase 13-E — Performance Budget Agent.
# Generated by tools/perf_budget.py and run via the editor's Python interp.

import json

import unreal


def measure_level(level_path: str) -> dict:
    """Return a snapshot of perf-relevant metrics for one level.

    Aura ships a per-domain perf agent; NYRA's whole-project Budget
    is a Tier 2 moat — we persist budgets and compare deltas against
    a baseline saved from a prior run, in-editor, no SaaS round-trip.
    """
    asset = unreal.load_asset(level_path)
    if asset is None:
        raise ValueError(f"level not found: {level_path}")

    # Stat snapshot via console — non-destructive read-only op.
    # The values come back via stat dump JSON; for v0 we capture the
    # primary actor + light + draw-call counts only.
    world = unreal.UnrealEditorSubsystem().get_editor_world()
    actors = unreal.GameplayStatics.get_all_actors_of_class(world, unreal.Actor)
    lights = unreal.GameplayStatics.get_all_actors_of_class(world, unreal.Light)
    static_meshes = unreal.GameplayStatics.get_all_actors_of_class(
        world, unreal.StaticMeshActor)

    return {
        "level_path": level_path,
        "actor_count": len(list(actors)),
        "light_count": len(list(lights)),
        "static_mesh_actor_count": len(list(static_meshes)),
    }


def main(spec_json: str):
    spec = json.loads(spec_json)
    levels = spec.get("levels", [])
    measurements = []
    for lvl in levels:
        try:
            measurements.append(measure_level(lvl))
        except ValueError as exc:
            measurements.append({"level_path": lvl, "error": str(exc)})
    out = {"measurements": measurements}
    print(f"NYRA PERF: measured {len(measurements)} level(s)")
    return json.dumps(out)


main('''${SPEC_JSON}''')
